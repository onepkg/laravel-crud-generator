{
    "name": "onepkg/laravel-crud-generator",
    "type": "library",
    "description": "OnePkg Laravel Generator",
    "keywords": ["laravel", "api", "model", "request", "resource", "crud", "generator"],
    "license": "MIT",
    "authors": [{
        "name": "li.chuhan",
        "email": "moxiaoxiaocheng@gmail.com"
    }],
    "require": {
        "php": "^7.3|^8.0",
        "laravel/framework": "^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "OnePkg\\LaravelCrudGenerator\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "\\OnePkg\\LaravelCrudGenerator\\LaravelCrudServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
